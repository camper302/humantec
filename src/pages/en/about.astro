---
// [기능] About Us 단일 페이지 스토리텔링(롱페이지)
// [원리]
// - 사용자가 스크롤로 자연스럽게 서사를 따라가도록(CEO → 연혁 → 경영이념 → 오시는 길) 섹션을 세로로 배치
// - 상단에 앵커 링크(목차)를 제공해 특정 섹션으로 즉시 점프 가능
// - 섹션은 1px 테두리/화이트 배경을 기본으로, 내부는 Bento Grid 철학(명확한 구획)으로 정보 밀도를 제어
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout lang="en" title="HUMANTEC | About Us" description="CEO message, history, philosophy, and location">
  <main class="mx-auto w-full max-w-5xl px-6 py-14 sm:py-16">
    <header class="flex flex-col gap-3">
      <p class="text-sm text-neutral-600">About Us</p>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Built on trust, delivered with precision</h1>
      <p class="max-w-2xl text-neutral-700">
        A single long-page narrative designed to be read naturally with scrolling.
      </p>
    </header>

    <div class="mt-8 rounded-2xl border border-neutral-200 bg-white p-3 sm:p-4">
      <div class="flex flex-wrap items-center gap-2">
        <a class="rounded-full border border-neutral-200 px-3 py-1.5 text-sm text-neutral-800 hover:bg-neutral-50" href="#ceo">
          CEO Message
        </a>
        <a class="rounded-full border border-neutral-200 px-3 py-1.5 text-sm text-neutral-800 hover:bg-neutral-50" href="#history">
          History
        </a>
        <a class="rounded-full border border-neutral-200 px-3 py-1.5 text-sm text-neutral-800 hover:bg-neutral-50" href="#philosophy">
          Philosophy
        </a>
        <a class="rounded-full border border-neutral-200 px-3 py-1.5 text-sm text-neutral-800 hover:bg-neutral-50" href="#location">
          Location
        </a>
      </div>
    </div>

    <section id="ceo" class="mt-10 scroll-mt-24">
      <div class="rounded-2xl border border-neutral-200 bg-white p-8">
        <div class="flex flex-col gap-2">
          <p class="text-xs font-medium text-neutral-600">Chapter 01</p>
          <h2 class="text-xl font-semibold tracking-tight">CEO Message</h2>
          <p class="max-w-2xl text-neutral-700">Content coming soon.</p>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="rounded-2xl border border-neutral-200 p-6">
            <p class="text-sm font-medium text-neutral-900">One-line summary</p>
            <p class="mt-2 text-sm text-neutral-700">Coming soon.</p>
          </div>
          <div class="rounded-2xl border border-neutral-200 p-6">
            <p class="text-sm font-medium text-neutral-900">Commitments</p>
            <p class="mt-2 text-sm text-neutral-700">Coming soon.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="history" class="mt-6 scroll-mt-24">
      <div class="rounded-2xl border border-neutral-200 bg-white p-8">
        <div class="flex flex-col gap-2">
          <p class="text-xs font-medium text-neutral-600">Chapter 02</p>
          <h2 class="text-xl font-semibold tracking-tight">History</h2>
          <p class="max-w-2xl text-neutral-700">Content coming soon.</p>
        </div>

        <div class="mt-6 grid gap-4 md:grid-cols-3">
          <div class="rounded-2xl border border-neutral-200 p-6">
            <p class="text-sm font-medium text-neutral-900">Early</p>
            <p class="mt-2 text-sm text-neutral-700">Coming soon.</p>
          </div>
          <div class="rounded-2xl border border-neutral-200 p-6">
            <p class="text-sm font-medium text-neutral-900">Growth</p>
            <p class="mt-2 text-sm text-neutral-700">Coming soon.</p>
          </div>
          <div class="rounded-2xl border border-neutral-200 p-6">
            <p class="text-sm font-medium text-neutral-900">Today</p>
            <p class="mt-2 text-sm text-neutral-700">Coming soon.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="philosophy" class="mt-6 scroll-mt-24">
      <div class="rounded-2xl border border-neutral-200 bg-white p-8">
        <div class="flex flex-col gap-2">
          <p class="text-xs font-medium text-neutral-600">Chapter 03</p>
          <h2 class="text-xl font-semibold tracking-tight">Philosophy</h2>
          <p class="max-w-2xl text-neutral-700">Content coming soon.</p>
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          <div class="rounded-2xl border border-neutral-200 p-6">
            <p class="text-sm font-medium text-neutral-900">Accuracy</p>
            <p class="mt-2 text-sm text-neutral-700">Coming soon.</p>
          </div>
          <div class="rounded-2xl border border-neutral-200 p-6">
            <p class="text-sm font-medium text-neutral-900">Consistency</p>
            <p class="mt-2 text-sm text-neutral-700">Coming soon.</p>
          </div>
          <div class="rounded-2xl border border-neutral-200 p-6">
            <p class="text-sm font-medium text-neutral-900">Ownership</p>
            <p class="mt-2 text-sm text-neutral-700">Coming soon.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="location" class="mt-6 scroll-mt-24">
      <div class="rounded-2xl border border-neutral-200 bg-white p-8">
        <div class="flex flex-col gap-2">
          <p class="text-xs font-medium text-neutral-600">Chapter 04</p>
          <h2 class="text-xl font-semibold tracking-tight">Location</h2>
          <p class="max-w-2xl text-neutral-700">We will connect map/address details here.</p>
        </div>

        <div class="mt-6 grid gap-4 lg:grid-cols-5">
          <div class="rounded-2xl border border-neutral-200 p-6 lg:col-span-3">
            <p class="text-sm font-medium text-neutral-900">Map</p>
            <div class="mt-3 aspect-video w-full rounded-xl border border-dashed border-neutral-200 bg-neutral-50"></div>
            <p class="mt-3 text-sm text-neutral-700">Map widget area.</p>
          </div>
          <div class="rounded-2xl border border-neutral-200 p-6 lg:col-span-2">
            <p class="text-sm font-medium text-neutral-900">Contact</p>
            <dl class="mt-3 grid gap-3 text-sm">
              <div>
                <dt class="text-neutral-600">Address</dt>
                <dd class="mt-1 text-neutral-900">Coming soon.</dd>
              </div>
              <div>
                <dt class="text-neutral-600">Phone</dt>
                <dd class="mt-1 text-neutral-900">Coming soon.</dd>
              </div>
              <div>
                <dt class="text-neutral-600">Email</dt>
                <dd class="mt-1 text-neutral-900">Coming soon.</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

