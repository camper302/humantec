---
// [기능] Products 단일 제품 포커스 뷰(Single-Item Focus)
// [원리]
// - 한 화면에 “하나의 제품군”만 크게 보여주어, 기술 사양/특징에 집중할 수 있게 설계
// - 상단 탭 전환으로 제품군(PCB/부자재/Machine)을 즉시 변경 (목록 나열 대신 집중형)
// - Bento Grid 구획으로 스펙/특징/적용 분야를 정리해, 데이터 중심 UI를 유지
import BaseLayout from "../../layouts/BaseLayout.astro";

const PRODUCT_GROUPS = [
  {
    id: "pcb",
    label: "PCB Materials",
    name: "High Reliability PCB Material",
    subtitle: "Focused view for specs & key characteristics",
    highlights: ["Thermal stability", "Process fit", "Traceability"],
    specs: [
      { k: "Thickness", v: "Coming soon." },
      { k: "Dk", v: "Coming soon." },
      { k: "Df", v: "Coming soon." },
      { k: "Heat", v: "Coming soon." },
    ],
    applications: ["High-layer PCB", "High-speed signal", "Industrial equipment"],
  },
  {
    id: "sub-materials",
    label: "Sub Materials",
    name: "Process Sub Materials",
    subtitle: "Stabilize quality and improve throughput",
    highlights: ["Stability", "Supply", "Cost optimization"],
    specs: [
      { k: "Spec", v: "Coming soon." },
      { k: "Compatibility", v: "Coming soon." },
      { k: "Packaging", v: "Coming soon." },
      { k: "Lead time", v: "Coming soon." },
    ],
    applications: ["Line operation", "Quality improvement", "Yield management"],
  },
  {
    id: "machine",
    label: "Machine",
    name: "Equipment / Machine",
    subtitle: "Production-oriented equipment lineup",
    highlights: ["Safety", "Maintainability", "Productivity"],
    specs: [
      { k: "Power", v: "Coming soon." },
      { k: "Dimensions", v: "Coming soon." },
      { k: "Throughput", v: "Coming soon." },
      { k: "Support", v: "Coming soon." },
    ],
    applications: ["Automation", "Inspection", "Process equipment"],
  },
];
---

<BaseLayout lang="en" title="HUMANTEC | Products" description="Products (PCB materials, sub materials, machine)">
  <main class="mx-auto w-full max-w-5xl px-6 py-14 sm:py-16">
    <header class="flex flex-col gap-3">
      <p class="text-sm text-neutral-600">Products</p>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Products</h1>
      <p class="max-w-2xl text-neutral-700">
        A single-item focus view to help users concentrate on technical specifications.
      </p>
    </header>

    <section class="mt-8 rounded-2xl border border-neutral-200 bg-white p-2 sm:p-3" aria-label="Category tabs">
      <div class="flex flex-wrap gap-1">
        {PRODUCT_GROUPS.map((g, idx) => (
          <button
            class:list={[
              "rounded-full px-3 py-2 text-sm font-medium transition-colors",
              idx === 0 ? "bg-neutral-900 text-white" : "text-neutral-800 hover:bg-neutral-50",
            ]}
            type="button"
            data-tab-trigger
            data-tab-id={g.id}
            aria-selected={idx === 0 ? "true" : "false"}
          >
            {g.label}
          </button>
        ))}
      </div>
    </section>

    <section class="mt-6 grid gap-6" aria-label="Focused product">
      {PRODUCT_GROUPS.map((g, idx) => (
        <div
          class:list={["rounded-2xl border border-neutral-200 bg-white p-8", idx === 0 ? "block" : "hidden"]}
          data-tab-panel
          data-tab-id={g.id}
        >
          <div class="flex flex-col gap-2">
            <p class="text-xs font-medium text-neutral-600">{g.label}</p>
            <h2 class="text-2xl font-semibold tracking-tight">{g.name}</h2>
            <p class="max-w-2xl text-neutral-700">{g.subtitle}</p>
          </div>

          <div class="mt-6 grid gap-4 lg:grid-cols-5">
            <div class="rounded-2xl border border-neutral-200 p-6 lg:col-span-3">
              <p class="text-sm font-medium text-neutral-900">Highlights</p>
              <ul class="mt-3 grid gap-2 text-sm text-neutral-700 sm:grid-cols-2">
                {g.highlights.map((h) => (
                  <li class="flex gap-2">
                    <span class="mt-1 h-1.5 w-1.5 rounded-full bg-neutral-400"></span>
                    <span>{h}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-6 grid gap-3 sm:grid-cols-2">
                {g.specs.map((s) => (
                  <div class="rounded-2xl border border-neutral-200 p-4">
                    <p class="text-xs font-medium text-neutral-600">{s.k}</p>
                    <p class="mt-2 text-sm text-neutral-900">{s.v}</p>
                  </div>
                ))}
              </div>
            </div>

            <div class="rounded-2xl border border-neutral-200 p-6 lg:col-span-2">
              <p class="text-sm font-medium text-neutral-900">Applications</p>
              <div class="mt-3 grid gap-2">
                {g.applications.map((a) => (
                  <div class="rounded-xl border border-neutral-200 px-3 py-2 text-sm text-neutral-800">
                    {a}
                  </div>
                ))}
              </div>

              <div class="mt-6 rounded-2xl border border-dashed border-neutral-200 bg-neutral-50 p-4">
                <p class="text-sm text-neutral-700">Image/datasheet area (to be connected later).</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </section>
  </main>
</BaseLayout>

<script is:inline>
  // [기능] Products 탭 전환
  // [원리] data-attribute 기반으로 trigger/panel을 매칭해, 선택된 제품군만 노출(단일 포커스)하고 aria 상태를 갱신
  window.addEventListener("DOMContentLoaded", () => {
    const triggers = Array.from(document.querySelectorAll("[data-tab-trigger]"));
    const panels = Array.from(document.querySelectorAll("[data-tab-panel]"));

    function setActive(id) {
      triggers.forEach((t) => {
        const isActive = t.getAttribute("data-tab-id") === id;
        t.setAttribute("aria-selected", String(isActive));
        t.classList.toggle("bg-neutral-900", isActive);
        t.classList.toggle("text-white", isActive);
        t.classList.toggle("text-neutral-800", !isActive);
      });

      panels.forEach((p) => {
        const isActive = p.getAttribute("data-tab-id") === id;
        p.classList.toggle("hidden", !isActive);
        p.classList.toggle("block", isActive);
      });
    }

    triggers.forEach((t) => {
      t.addEventListener("click", () => {
        const id = t.getAttribute("data-tab-id");
        if (!id) return;
        setActive(id);
      });
    });
  });
</script>

