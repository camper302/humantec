---
// [기능] Support 페이지 골격
// [원리] Client Portal(로그인) 진입로로서 문의/자료실/지원 요청으로 이어지는 허브 역할 수행
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout lang="en" title="HUMANTEC | Support" description="Support hub and client portal entry">
  <main class="mx-auto w-full max-w-5xl px-6 py-16">
    <header class="flex flex-col gap-3">
      <p class="text-sm text-neutral-600">Support</p>
      <h1 class="text-3xl font-semibold tracking-tight">Support</h1>
      <p class="max-w-2xl text-neutral-700">
        Entry page skeleton for the client portal. Auth wiring will come next.
      </p>
    </header>

    <section class="mt-10 grid gap-4 md:grid-cols-2">
      <a class="rounded-2xl border border-neutral-200 p-8 hover:bg-neutral-50" href="#">
        <h2 class="text-lg font-semibold">Client Portal</h2>
        <p class="mt-2 text-neutral-700">Log in to access docs and support features.</p>
      </a>
      <a class="rounded-2xl border border-neutral-200 p-8 hover:bg-neutral-50" href="#">
        <h2 class="text-lg font-semibold">Contact</h2>
        <p class="mt-2 text-neutral-700">We will connect a unified inquiry form here.</p>
      </a>
    </section>
  </main>
</BaseLayout>

