---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout lang="en" title="HUMANTEC" description="Humantec showcase home">
  <main class="mx-auto w-full max-w-5xl px-6 py-16">
    <div class="rounded-2xl border border-neutral-200 bg-white p-10">
      <p class="text-sm text-neutral-600">HUMANTEC</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight">Humantec Showcase</h1>
      <p class="mt-3 max-w-2xl text-neutral-700">
        We will build a Vercel-inspired minimal UI with i18n routing and a client portal.
      </p>
    </div>
  </main>
</BaseLayout>

