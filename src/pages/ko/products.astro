---
// [기능] Products 페이지 골격
// [원리] PCB/부자재/Machine 카테고리 기반 필터 UI를 제공하고, 상세는 추후 content/lib 연동으로 확장
import BaseLayout from "../../layouts/BaseLayout.astro";

const CATEGORIES = [
  { id: "pcb", label: "PCB 재료" },
  { id: "sub-materials", label: "부자재" },
  { id: "machine", label: "Machine" },
];
---

<BaseLayout lang="ko" title="휴먼텍 | Products" description="휴먼텍 제품 (PCB 재료/부자재/Machine)">
  <main class="mx-auto w-full max-w-5xl px-6 py-16">
    <header class="flex flex-col gap-3">
      <p class="text-sm text-neutral-600">Products</p>
      <h1 class="text-3xl font-semibold tracking-tight">제품</h1>
      <p class="max-w-2xl text-neutral-700">
        카테고리 필터링 기반의 제품 목록 골격입니다. (데이터 연동은 다음 단계에서 진행)
      </p>
    </header>

    <section class="mt-10 rounded-2xl border border-neutral-200 p-6">
      <h2 class="text-sm font-medium text-neutral-600">카테고리</h2>
      <div class="mt-3 flex flex-wrap gap-2">
        {CATEGORIES.map((c) => (
          <a
            class="rounded-full border border-neutral-200 px-3 py-1.5 text-sm text-neutral-800 hover:bg-neutral-50"
            href={`?category=${c.id}`}
          >
            {c.label}
          </a>
        ))}
      </div>
    </section>

    <section class="mt-6 grid gap-4">
      <div class="rounded-2xl border border-neutral-200 p-8">
        <h2 class="text-lg font-semibold">제품 리스트</h2>
        <p class="mt-2 text-neutral-700">필터 선택에 따라 목록이 렌더링되도록 확장 예정입니다.</p>
      </div>
    </section>
  </main>
</BaseLayout>

